OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Observability — values come from WSO2 Agent Manager after registering
# the agent as an Externally-Hosted Agent.
AMP_OTEL_ENDPOINT=
AMP_AGENT_API_KEY=

# Identity (Module 02)
IDP_TOKEN_ENDPOINT=http://localhost:9700/oauth2/token
IDP_LOGIN_ENDPOINT=http://localhost:9700/oauth2/login
AGENT_CLIENT_ID=grand-meridian-concierge
AGENT_CLIENT_SECRET=agent-secret
BOOKING_URL=http://localhost:9001

# Shared between mock IdP and mock booking service. Replaced by
# Asgardeo's signing keys in production.
IDP_SECRET=dev-only-secret-do-not-use-in-production

# Set to "shared_key" to demo the wrong way (module 02, step 1).
# Unset (or "agent_identity") for the right way.
# BOOKING_MODE=shared_key
