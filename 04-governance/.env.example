OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Observability — values come from WSO2 Agent Manager after registering
# the agent as an Externally-Hosted Agent (module 01).
AMP_OTEL_ENDPOINT=
AMP_AGENT_API_KEY=

# Governance — set OPENAI_BASE_URL to the LLM Service Provider gateway
# URL surfaced by AM, and replace OPENAI_API_KEY above with the
# AM-issued JWT for that LSP. The agent code (see _resolve_openai_config
# in agent.py) detects governed mode by the presence of
# OPENAI_BASE_URL and routes the call through AM's gateway with the
# token attached on the `API-Key` header.
#
# Unset OPENAI_BASE_URL to revert to BYO mode (direct to OpenAI).
# OPENAI_BASE_URL=https://YOUR-AM-DEPLOYMENT/projects/hospitality/llm-service-providers/openai/
